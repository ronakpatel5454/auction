# Supabase (Public variables meant for the React frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase (Private variables for backend/edge functions - do NOT prefix with VITE_ if used in frontend to prevent leaks)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudinary (Frontend Upload uses Cloud Name + Unsigned Preset)
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-upload-preset

# Cloudinary Backend API Keys (Do NOT prefix with VITE_)
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
